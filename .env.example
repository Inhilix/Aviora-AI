# Database
POSTGRES_DB=studyai
POSTGRES_USER=studyai_user
POSTGRES_PASSWORD=<strong-random-password>
DATABASE_URL=postgresql+asyncpg://studyai_user:<password>@postgres:5432/studyai

# Redis
REDIS_URL=redis://redis:6379/0

# JWT — generate with: openssl genrsa -out private.pem 2048
JWT_PRIVATE_KEY=<contents of private.pem>
JWT_PUBLIC_KEY=<contents of public.pem>

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...
HAIKU_MODEL=claude-haiku-4-5
DAILY_COST_CEILING_USD=5.00
DAILY_TOKEN_LIMIT_PER_USER=50000

# Guardrail
GUARDRAIL_URL=http://guardrail:8002/classify

# NAS
NAS_MOUNT_PATH=/data
NAS_IP=<NAS local IP>

# Email
SMTP_HOST=<your SMTP>
SMTP_PORT=587
SMTP_USER=<email>
SMTP_PASSWORD=<password>

# Encryption
AES_MASTER_KEY=<32-byte hex key>

# App
APP_ENV=production
DEBUG=false
DOMAIN=yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com
